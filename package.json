{
	"name": "groundwire",
	"version": "3.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"format": "prettier --write \"src/**/*.ts\" \"*.{json,md,yml}\"",
		"format:check": "prettier --check \"src/**/*.ts\" \"*.{json,md,yml}\"",
		"build": "wrangler deploy --dry-run",
		"prepare": "husky"
	},
	"dependencies": {
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260410.1",
		"@eslint/js": "^10.0.1",
		"eslint": "^10.2.0",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vitest": "^4.1.4",
		"wrangler": "^4.81.1"
	}
}
